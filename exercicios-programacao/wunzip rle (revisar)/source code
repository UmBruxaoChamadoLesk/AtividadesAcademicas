#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

int main(int argc, char* argv[]) {
    FILE* fp;
    char c;
    int count;

    if (argc < 2) {
        printf("Siga o formato: %s [arquivo1] [arquivo2]...\n", argv[0]);
        return 1;
    }

    int i = 1;
    while (i < argc) {
        fp = fopen(argv[i], "r");

        if (fp == NULL) {
            printf("Arquivo %s nao encontrado\n", argv[i]);
            i++;
            continue;
        }

        while (fscanf(fp, "%d", &count) == 1) {
            if (fscanf(fp, "%c", &c) == 1) {
                if (isprint(c)) { // Verifica se o caractere é imprimível
                    for (int j = 0; j < count; j++) {
                        printf("%c", c); // Repete o caractere count vezes
                    }
                }
            }
        }

        fclose(fp);
        i++;
    }
    printf("\n");
    return 0;
}
